# ── Required ──
AM_ANTHROPIC_API_KEY=sk-ant-...
AM_LIBRARY_PATH=/path/to/calibre/library

# ── Server (defaults work fine) ──
AM_HOST=0.0.0.0
AM_PORT=9000
AM_BASE_URL=http://localhost:9000
AM_TEMP_DIR=/tmp/agents-matrix
AM_ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── x402 Payment (optional — leave empty to disable) ──
AM_WALLET_ADDRESS=
AM_FACILITATOR_URL=https://x402.org/facilitator
AM_CHAIN_NETWORK=eip155:84532

# ── ERC-8004 Registration (optional — only for ./scripts/register.sh) ──
AM_PRIVATE_KEY=
AM_CHAIN_ID=84532
AM_RPC_URL=
AM_PINATA_JWT=
